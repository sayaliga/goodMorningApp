<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- 🌼 Your main app theme -->
    <style name="Theme.GoodmorningApp" parent="Theme.Material3.Light.NoActionBar">
        <!-- You can safely remove colorPrimary/colorSecondary. -->
        <item name="android:statusBarColor" tools:targetApi="l">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- 🌞 Splash screen theme -->
    <style name="Theme.GoodmorningApp.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FFF8E1</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/surise_logo</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <item name="postSplashScreenTheme">@style/Theme.GoodmorningApp</item>
    </style>

</resources>
