gitignore
# Created by https://www.toptal.com/developers/gitignore/api/android,android-studio,kotlin
# Edit at https://www.toptal.com/developers/gitignore?templates=android,android-studio,kotlin

### Android ###
# Built application files
*.apk
*.aab
*.ap_

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# Gradle files
.gradle/
build/

# Local configuration files (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor files
.navigation/

# Android Studio captures folder
captures/

# Keystore files
*.jks
*.keystore

# External native build folder generated in Android Studio 2.2 and later
.cxx/

# Google Services (e.g. Google Crashlytics)
google-services.json

# Signed bundle and APK files from signingConfigs
*/*-signed.apk
*/*-signed.aab

# Play Store listing and screenshot files (if you don't want to version them)
/app/src/main/play/

# Android Studio IDE files
.idea/caches/
.idea/libraries/
.idea/modules.xml
.idea/workspace.xml
.idea/navEditor.xml
.idea/assetWizardSettings.xml
*.iml

# PostHog/Sentry properties file (if it contains sensitive DSNs)
sentry.properties

# END of https://www.toptal.com/developers/gitignore/api/android,android-studio,kotlin
